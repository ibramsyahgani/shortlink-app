# ============================================================
# Salin file ini ke .env.local dan isi dengan nilai asli
# JANGAN commit .env.local ke git!
# ============================================================

# URL Cloudflare Worker kamu (setelah deploy worker)
NEXT_PUBLIC_WORKER_URL=https://shortlink-api.YOUR_SUBDOMAIN.workers.dev

# Secret yang sama dengan di wrangler.toml
WORKER_SECRET=GANTI_DENGAN_SECRET_PANJANG_RANDOM

# Resend API Key untuk kirim magic link email
RESEND_API_KEY=re_XXXXXXXXXXXXXXXXXXXXXXXX

# Email pengirim (harus verified di Resend)
FROM_EMAIL=noreply@yourdomain.com

# Domain app kamu (untuk link di email)
NEXT_PUBLIC_APP_URL=https://shortlink-app.vercel.app

# NextAuth secret (buat dengan: openssl rand -base64 32)
AUTH_SECRET=GANTI_DENGAN_RANDOM_STRING_PANJANG
